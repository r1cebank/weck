      "valueName": "DisableWindowsConsumerFeatures",
      "type": "DWord",
      "value": 1,
      "enabledByDefault": true,
      "reversible": true
    },
    {
      "id": "disable_suggested_content",
      "name": "Disable suggested content",
      "description": "Disable selected suggested content experiences for the current user.",
      "path": "HKCU:\\Software\\Microsoft\\Windows\\CurrentVersion\\ContentDeliveryManager",
      "valueName": "SubscribedContent-338389Enabled",
      "type": "DWord",
      "value": 0,
      "enabledByDefault": true,
      "reversible": true
    },
    {
      "id": "disable_activity_history",
      "name": "Disable activity history",
      "description": "Disable publishing user activities to Windows Timeline activity history.",
      "path": "HKLM:\\SOFTWARE\\Policies\\Microsoft\\Windows\\System",
      "valueName": "PublishUserActivities",
      "type": "DWord",
      "value": 0,
      "enabledByDefault": true,
      "reversible": true
    },
    {
      "id": "disable_bing_search",
      "name": "Disable Bing web search",
