      "path": "HKCU:\\Software\\Microsoft\\Windows\\CurrentVersion\\Search",
      "valueName": "BingSearchEnabled",
      "type": "DWord",
      "value": 0,
      "enabledByDefault": true,
      "reversible": true
    },
    {
      "id": "disable_game_dvr",
      "name": "Disable Game DVR",
      "description": "Disable Game DVR capture for the current user.",
      "path": "HKCU:\\System\\GameConfigStore",
      "valueName": "GameDVR_Enabled",
      "type": "DWord",
      "value": 0,
      "enabledByDefault": true,
      "reversible": true
    },
    {
      "id": "disable_edge_startup_boost",
      "name": "Disable Edge startup boost",
      "description": "Disable Microsoft Edge startup boost through policy.",
      "path": "HKLM:\\SOFTWARE\\Policies\\Microsoft\\Edge",
      "valueName": "StartupBoostEnabled",
      "type": "DWord",
      "value": 0,
      "enabledByDefault": true,
      "reversible": true
    },
    {
      "id": "disable_edge_background_mode",
      "name": "Disable Edge background mode",
      "description": "Disable Microsoft Edge background mode through policy.",
      "path": "HKLM:\\SOFTWARE\\Policies\\Microsoft\\Edge",
