{
  "schemaVersion": "0.1.0",
  "tweaks": [
    {
      "id": "show_file_extensions",
      "name": "Show file extensions",
      "description": "Show known file extensions in File Explorer.",
      "path": "HKCU:\\Software\\Microsoft\\Windows\\CurrentVersion\\Explorer\\Advanced",
      "valueName": "HideFileExt",
      "type": "DWord",
      "value": 0,
      "enabledByDefault": true,
      "reversible": true
    },
    {
      "id": "show_hidden_files",
      "name": "Show hidden files",
      "description": "Show hidden files and folders in File Explorer.",
      "path": "HKCU:\\Software\\Microsoft\\Windows\\CurrentVersion\\Explorer\\Advanced",
      "valueName": "Hidden",
      "type": "DWord",
      "value": 1,
      "enabledByDefault": true,
      "reversible": true
    },
    {
      "id": "open_explorer_this_pc",
      "name": "Open Explorer to This PC",
      "description": "Open File Explorer to This PC instead of Quick Access.",
      "path": "HKCU:\\Software\\Microsoft\\Windows\\CurrentVersion\\Explorer\\Advanced",
      "valueName": "LaunchTo",
      "type": "DWord",
      "value": 1,
      "enabledByDefault": true,
      "reversible": true
    },
    {
      "id": "disable_advertising_id",
      "name": "Disable advertising ID",
      "description": "Disable the per-user advertising ID.",
      "path": "HKCU:\\Software\\Microsoft\\Windows\\CurrentVersion\\AdvertisingInfo",
      "valueName": "Enabled",
      "type": "DWord",
      "value": 0,
      "enabledByDefault": true,
      "reversible": true
    },
    {
      "id": "disable_consumer_features",
      "name": "Disable consumer features",
      "description": "Disable Windows consumer feature suggestions through policy.",
